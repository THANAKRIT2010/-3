    TeleportTab:AddButton({ Title = "วาปไปหาผู้เล่น", Callback = function() if SelectedTPPlayer and SelectedTPPlayer.Character then LocalPlayer.Character.HumanoidRootPart.CFrame = SelectedTPPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-3) end end })
    TeleportTab:AddButton({ Title = "มองจอผู้เล่น", Callback = function() if SelectedTPPlayer and SelectedTPPlayer.Character then Camera.CameraSubject = SelectedTPPlayer.Character:FindFirstChildOfClass("Humanoid") end end })
    TeleportTab:AddButton({ Title = "ยกเลิกมองจอ", Callback = function() if LocalPlayer.Character then Camera.CameraSubject = LocalPlayer.Character:FindFirstChildOfClass("Humanoid") end end })

    -- 5. SIT PLAYER TAB
    local SitTab = Window:AddTab({ Title = "Sit Player", Icon = "user" })
    local SelectedSitPlayer = nil
    local SitType = "Head"
    local AlignPos, AlignOri, MyAttachment, TargetAttachment

    local function StopSit()
        if AlignPos then AlignPos:Destroy() AlignPos = nil end
        if AlignOri then AlignOri:Destroy() AlignOri = nil end
        if MyAttachment then MyAttachment:Destroy() MyAttachment = nil end
        if TargetAttachment then TargetAttachment:Destroy() TargetAttachment = nil end
    end

    local function StartSit()
        StopSit()
        if not (SelectedSitPlayer and SelectedSitPlayer.Character and LocalPlayer.Character) then return end
        local targetHRP = SelectedSitPlayer.Character:FindFirstChild("HumanoidRootPart")
        local myChar = LocalPlayer.Character
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        local myHum = myChar:FindFirstChildOfClass("Humanoid")
        if not (targetHRP and myHRP and myHum) then return end

        myHum.Sit = true
        myHum:ChangeState(Enum.HumanoidStateType.Seated)
        MyAttachment = Instance.new("Attachment", myHRP)
        TargetAttachment = Instance.new("Attachment", targetHRP)

        if SitType == "Head" then
            TargetAttachment.Position = Vector3.new(0, 2.5, 0)
        elseif SitType == "Back" then
            TargetAttachment.Position = Vector3.new(0, 0.5, -1.2)
            TargetAttachment.Orientation = Vector3.new(0, 180, 0)
        end

        AlignPos = Instance.new("AlignPosition", myHRP)
        AlignPos.Attachment0, AlignPos.Attachment1 = MyAttachment, TargetAttachment
        AlignPos.RigidityEnabled = true

        AlignOri = Instance.new("AlignOrientation", myHRP)
        AlignOri.Attachment0, AlignOri.Attachment1 = MyAttachment, TargetAttachment
        AlignOri.RigidityEnabled = true
    end

    local SitPlayerDrop = SitTab:AddDropdown("SitDrop", {
        Title = "เลือกผู้เล่น",
        Values = GetPlayers(),
        Callback = function(v) SelectedSitPlayer = Players:FindFirstChild(v) end
    })

    task.spawn(function()
        while true do task.wait(2) SitPlayerDrop:SetValues(GetPlayers()) end
    end)

    SitTab:AddButton({ Title = "นั่งบนหัว 🪑", Callback = function() SitType = "Head" StartSit() end })
    SitTab:AddButton({ Title = "นั่งติดหลัง 🔙", Callback = function() SitType = "Back" StartSit() end })
    SitTab:AddButton({ Title = "หยุดนั่ง ❌", Callback = function() StopSit() end })

    -- 6. SERVER HOP TAB
    local HopTab = Window:AddTab({ Title = "Server Hop", Icon = "server" })
    local function HopToLowServer()
        local HttpService = game:GetService("HttpService")
        local response = game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
        local data = HttpService:JSONDecode(response)
        if data and data.data then
            for _, server in pairs(data.data) do
                if server.playing < server.maxPlayers and server.id ~= game.JobId then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id)
                    return
                end
            end
        end
    end

    HopTab:AddSection("Server Manager")
    HopTab:AddButton({
        Title = "🌑 Join Low Player Server",
        Callback = function()
            Window:Dialog({
                Title = "ย้ายเซิร์ฟเวอร์",
                Content = "ต้องการย้ายไปห้องคนน้อยใช่ไหม?",
                Buttons = {
                    { Title = "ยืนยัน", Callback = HopToLowServer },
                    { Title = "ยกเลิก" }
                }
            })
        end
    })

