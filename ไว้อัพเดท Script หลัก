    TeleportTab:AddButton({ Title = "วาปไปหาผู้เล่น", Callback = function() if SelectedPlayer and SelectedPlayer.Character then LocalPlayer.Character.HumanoidRootPart.CFrame = SelectedPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-3) end end })
    TeleportTab:AddButton({ Title = "มองจอผู้เล่น", Callback = function() if SelectedPlayer and SelectedPlayer.Character then Camera.CameraSubject = SelectedPlayer.Character:FindFirstChildOfClass("Humanoid") end end })
    TeleportTab:AddButton({ Title = "ยกเลิกมองจอ", Callback = function() if LocalPlayer.Character then Camera.CameraSubject = LocalPlayer.Character:FindFirstChildOfClass("Humanoid") end end })

    -- 5. MUSIC TAB
    local MusicTab = Window:AddTab({ Title = "Music", Icon = "music" })
    local MusicInfo = MusicTab:AddParagraph({ Title = "ข้อมูลเพลง", Content = "ยังไม่มีข้อมูล" })

    MusicTab:AddButton({ Title = "ก๊อปเพลงคนใกล้ที่สุด", Callback = function()
        local nearest, shortest = nil, math.huge
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local d = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if d < shortest then shortest = d nearest = p end
            end
        end
        
        if nearest then
            for _, v in pairs(nearest.Character:GetDescendants()) do
                if v:IsA("Sound") and v.SoundId ~= "" then
                    local id = v.SoundId:match("%d+")
                    if id then
                        setclipboard(id)
                        MusicInfo:SetTitle("พบคลิปบอร์ด!")
                        MusicInfo:SetContent("ID: " .. id .. " จาก " .. nearest.Name .. " (ก๊อปแล้ว)")
                        return
                    end
                end
            end
        end
        Fluent:Notify({Title = "แจ้งเตือน", Content = "ไม่พบเพลง", Duration = 2})
    end})

    -- 6. CONTACT TAB
