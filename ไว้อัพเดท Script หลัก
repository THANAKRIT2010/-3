local function LoadMain()
    if Unlocked then return end
    Unlocked = true

    -- 1. PLAYER TAB
    local PlayerTab = Window:AddTab({ Title = "Player", Icon = "user" })
    
    PlayerTab:AddButton({
        Title = "รีเซ็ตตัวละคร",
        Callback = function()
            if LocalPlayer.Character then LocalPlayer.Character:BreakJoints() end
        end
    })

    -- ESP Logic
    local ESPEnabled, NameEnabled, DistanceEnabled, TracerEnabled = false, false, false, false
    local ESPObjects = {}

    local function CreateESP(player)
        if player == LocalPlayer then return end
        local function Setup(character)
            local hrp = character:WaitForChild("HumanoidRootPart", 10)
            if not hrp then return end
            
            local highlight = Instance.new("Highlight")
            highlight.FillTransparency = 1
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.Parent = character
            
            local bill = Instance.new("BillboardGui")
            bill.Size = UDim2.new(0, 120, 0, 30)
            bill.StudsOffset = Vector3.new(0, 2.8, 0)
            bill.AlwaysOnTop = true
            bill.Parent = hrp
            
            local label = Instance.new("TextLabel")
            label.Size = UDim2.new(1, 0, 1, 0)
            label.BackgroundTransparency = 1
            label.TextColor3 = Color3.new(1, 1, 1)
            label.Font = Enum.Font.GothamBold
            label.TextSize = 14
            label.Parent = bill
            
            local tracer = Drawing.new("Line")
            tracer.Thickness = 1.5
            tracer.Color = Color3.new(1, 1, 1)
            
            ESPObjects[player] = {Highlight = highlight, Billboard = bill, Label = label, Tracer = tracer, HRP = hrp}
        end
        if player.Character then Setup(player.Character) end
        player.CharacterAdded:Connect(Setup)
    end

    for _, plr in pairs(Players:GetPlayers()) do CreateESP(plr) end
    Players.PlayerAdded:Connect(CreateESP)

    RunService.RenderStepped:Connect(function()
        for player, data in pairs(ESPObjects) do
            if player.Character and data.HRP and data.HRP.Parent then
                local dist = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - data.HRP.Position).Magnitude)
                local text = ""
                if NameEnabled then text = player.Name end
                if DistanceEnabled then text = text .. (text ~= "" and " " or "") .. "[" .. dist .. "m]" end
                
                data.Label.Text = text
                data.Highlight.Enabled = ESPEnabled
                data.Billboard.Enabled = (NameEnabled or DistanceEnabled)
                
                if TracerEnabled then
                    local pos, onScreen = Camera:WorldToViewportPoint(data.HRP.Position)
                    if onScreen then
                        data.Tracer.Visible = true
                        data.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                        data.Tracer.To = Vector2.new(pos.X, pos.Y)
                    else data.Tracer.Visible = false end
                else data.Tracer.Visible = false end
            else
                if data.Tracer then data.Tracer.Visible = false end
            end
        end
    end)

    PlayerTab:AddToggle("ESPTog", {Title = "เปิดกรอบผู้เล่น", Default = false, Callback = function(v) ESPEnabled = v end})
    PlayerTab:AddToggle("NameTog", {Title = "เปิดชื่อ", Default = false, Callback = function(v) NameEnabled = v end})
    PlayerTab:AddToggle("DistTog", {Title = "เปิดระยะ", Default = false, Callback = function(v) DistanceEnabled = v end})
    PlayerTab:AddToggle("TracerTog", {Title = "เปิดเส้นโยง", Default = false, Callback = function(v) TracerEnabled = v end})

    -- 2. SCRIPTS TAB
    local ScriptTab = Window:AddTab({ Title = "Scripts", Icon = "code" })
    ScriptTab:AddButton({ Title = "AUTO มันนี่💵", Callback = function() loadstring(game:HttpGet("https://raw.githubusercontent.com/THANAKRIT2010/Thai-2/refs/heads/main/TK1669", true))() end })
    ScriptTab:AddButton({ Title = "BOOTS FPS🍃", Callback = function() loadstring(game:HttpGet("https://rawscripts.net/raw/Universal-Script-Boostfps-26436"))() end })
    ScriptTab:AddButton({ Title = "SET TELEPORT📍", Callback = function() loadstring(game:HttpGet("https://raw.githubusercontent.com/qqthanakrit99-code/-/refs/heads/main/%E0%B8%88%E0%B8%B3%E0%B8%88%E0%B8%B8%E0%B8%94%E0%B8%A7%E0%B8%B2%E0%B8%9B", true))() end })

    -- 3. SPEED TAB
    local SpeedTab = Window:AddTab({ Title = "Speed", Icon = "zap" })
    local SpeedEnabled, CurrentSpeed = false, 16
    local TPWalkEnabled, TPWalkSpeed = false, 6
    local currentVelocity = Vector3.new()

    SpeedTab:AddToggle("SpeedTog", {Title = "เปิด WalkSpeed", Default = false, Callback = function(v) SpeedEnabled = v end})
    SpeedTab:AddSlider("SpeedSlider", {Title = "ปรับความเร็ว", Min = 16, Max = 250, Default = 16, Rounding = 1, Callback = function(v) CurrentSpeed = v end})
    SpeedTab:AddToggle("TPWalkTog", {Title = "เปิด TPWalk (สมูท)", Default = false, Callback = function(v) TPWalkEnabled = v end})
    SpeedTab:AddSlider("TPWalkSlider", {Title = "ความเร็ว TPWalk", Min = 1, Max = 30, Default = 6, Rounding = 1, Callback = function(v) TPWalkSpeed = v end})

    RunService.RenderStepped:Connect(function(dt)
        local char = LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hum and hrp then
            if SpeedEnabled then hum.WalkSpeed = CurrentSpeed else hum.WalkSpeed = 16 end
            if TPWalkEnabled and hum.MoveDirection.Magnitude > 0 then
                local targetVelocity = hum.MoveDirection.Unit * TPWalkSpeed
                currentVelocity = currentVelocity:Lerp(targetVelocity, 0.15)
                hrp.CFrame = hrp.CFrame + (currentVelocity * dt * 60)
            else currentVelocity = Vector3.new() end
        end
    end)

    -- 4. TELEPORT TAB
    local TeleportTab = Window:AddTab({ Title = "Teleport", Icon = "map-pin" })
    local SelectedPlayer = nil
    local function GetPlayers() local t = {} for _,p in pairs(Players:GetPlayers()) do if p ~= LocalPlayer then table.insert(t, p.Name) end end return t end

    local PlayerDrop = TeleportTab:AddDropdown("TPDrop", {
        Title = "เลือกผู้เล่น",
        Values = GetPlayers(),
        Callback = function(v) SelectedPlayer = Players:FindFirstChild(v) end
    })
    
    -- Auto Refresh Dropdown
    Players.PlayerAdded:Connect(function() PlayerDrop:SetValues(GetPlayers()) end)
    Players.PlayerRemoving:Connect(function() PlayerDrop:SetValues(GetPlayers()) end)

    TeleportTab:AddButton({ Title = "วาปไปหาผู้เล่น", Callback = function() if SelectedPlayer and SelectedPlayer.Character then LocalPlayer.Character.HumanoidRootPart.CFrame = SelectedPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-3) end end })
    TeleportTab:AddButton({ Title = "มองจอผู้เล่น", Callback = function() if SelectedPlayer and SelectedPlayer.Character then Camera.CameraSubject = SelectedPlayer.Character:FindFirstChildOfClass("Humanoid") end end })
    TeleportTab:AddButton({ Title = "ยกเลิกมองจอ", Callback = function() if LocalPlayer.Character then Camera.CameraSubject = LocalPlayer.Character:FindFirstChildOfClass("Humanoid") end end })

    -- 5. MUSIC TAB
    local MusicTab = Window:AddTab({ Title = "Music", Icon = "music" })
    local MusicInfo = MusicTab:AddParagraph({ Title = "ข้อมูลเพลง", Content = "ยังไม่มีข้อมูล" })

    MusicTab:AddButton({ Title = "ก๊อปเพลงคนใกล้ที่สุด", Callback = function()
        local nearest, shortest = nil, math.huge
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local d = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
                if d < shortest then shortest = d nearest = p end
            end
        end
        
        if nearest then
            for _, v in pairs(nearest.Character:GetDescendants()) do
                if v:IsA("Sound") and v.SoundId ~= "" then
                    local id = v.SoundId:match("%d+")
                    if id then
                        setclipboard(id)
                        MusicInfo:SetTitle("พบคลิปบอร์ด!")
                        MusicInfo:SetContent("ID: " .. id .. " จาก " .. nearest.Name .. " (ก๊อปแล้ว)")
                        return
                    end
                end
            end
        end
        Fluent:Notify({Title = "แจ้งเตือน", Content = "ไม่พบเพลง", Duration = 2})
    end})

    -- 6. CONTACT TAB
    local ContactTab = Window:AddTab({ Title = "Contact", Icon = "phone" })
    ContactTab:AddButton({ Title = "รีเข้าแมพ", Callback = function() TeleportService:Teleport(game.PlaceId) end })
    ContactTab:AddButton({ Title = "Discord", Callback = function() setclipboard("https://discord.gg/XKJTssDUSR") end })
    ContactTab:AddButton({ Title = "instagram", Callback = function() setclipboard("https://www.instagram.com/ezmxyxii/") end })
end


